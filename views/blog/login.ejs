<%-include('../includes/head.ejs')%>
<link rel="stylesheet" href="/css/blog-login.css">
    <%-include('../includes/navigation.ejs')%>
    <div class="login">
        <div class="img-container"></div>
        <span class="loginTitle">Sign In</span>
        <% if (errorMessage) { %>
            <div class="mb-3" style="color:red;">
                <%= errorMessage %>
            </div>
            <% } %>
                <form action="/blog/login" method="POST" class="loginForm">
                    <label for="email">Email</label>
                    <input class="loginInput form-control" type="text" name="email" id="email"
                        placeholder="Enter your email..." value="<%=oldInputs.email%>" />
                    <label for="password">Password</label>
                    <input class="loginInput form-control" id="password" type="password" name="password"
                        placeholder="Enter your password..." />
                    <input type="hidden" name="_csrf" value="<%=csrfToken%>">
                    <button class="loginButton mt-4" type="submit">Login</button>
                </form>
    </div>
        <%-include('../includes/end.ejs') %>
        <script src="/js/non-home.js"></script>